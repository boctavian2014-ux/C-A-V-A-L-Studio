{
  "name": "caval-studio",
  "version": "0.1.0",
  "private": true,
  "productName": "CAVALO",
  "description": "CAVALO — IDE romanesc premium cu AI frontier, Context Engine si Romania Layer.",
  "main": "dist/main/electron-main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build:css": "postcss styles/pulse-tech.css -o dist/renderer/pulse-tech.css",
    "build:icons": "tsx scripts/build-icons.ts",
    "build": "npm run clean && webpack --mode production && npm run build:css && node scripts/copy-renderer-static.js",
    "build:dev": "node scripts/prune-renderer-bundle.js && webpack --mode development && npm run build:css && node scripts/copy-renderer-static.js",
    "dist": "electron-builder --config installer/config/electron-builder.yml",
    "dist:all": "tsx installer/scripts/build-all.ts",
    "dist:win": "tsx installer/scripts/build-windows.ts",
    "dist:mac": "tsx installer/scripts/build-macos.ts",
    "dist:linux": "tsx installer/scripts/build-linux.ts",
    "release:publish": "tsx installer/scripts/publish-release.ts",
    "cicd:test": "tsx .cicd/scripts/run-tests.ts",
    "cicd:build-installer": "tsx .cicd/scripts/build-installer.ts",
    "cicd:sign": "tsx .cicd/scripts/sign-artifacts.ts",
    "cicd:publish-release": "tsx .cicd/scripts/publish-release.ts",
    "cicd:publish-marketplace": "tsx .cicd/scripts/publish-marketplace.ts",
    "dev": "webpack --mode development --watch",
    "dev:all": "npx concurrently -k \"npm run dev\" \"npm start\"",
    "start": "node scripts/ensure-built.js && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ftce": "tsx scripts/run-full-test-coverage.ts",
    "audit": "tsx scripts/full-audit-engine.ts",
    "assets:neon-transparent": "tsx scripts/process-neon-horse-transparent.ts",
    "lint": "eslint \"{src,ai,context-engine,romania,marketplace,ui-kit,billing,admin,mobile-app,components}/**/*.{ts,tsx}\"",
    "marketplace:serve": "tsx marketplace/server/standalone.ts",
    "billing:serve": "tsx billing/standalone.ts",
    "cad:serve": "tsx engineering/cad-server/standalone.ts",
    "docs": "node scripts/print-roadmap.js"
  },
  "keywords": [
    "ide",
    "electron",
    "typescript",
    "ai",
    "romania",
    "vscode-fork"
  ],
  "author": "CAVALO",
  "license": "UNLICENSED",
  "build": {
    "productName": "CAVALO",
    "mac": {
      "icon": "build-icons/icon.icns"
    },
    "win": {
      "icon": "build-icons/icon.ico"
    },
    "linux": {
      "icon": "build-icons/icon.png"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/dagre": "^0.7.54",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.175.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.5.0",
    "css-loader": "^7.1.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "png-to-ico": "^2.1.8",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.3",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-loader": "^9.6.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.6",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.1.2",
    "@supabase/supabase-js": "^2.108.2",
    "@xyflow/react": "^12.11.1",
    "cors": "^2.8.6",
    "dagre": "^0.8.5",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.2.3",
    "three": "^0.175.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
