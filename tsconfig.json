{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022", "DOM"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "ai/**/*.ts",
    "ai/**/*.tsx",
    "mobile/**/*.ts",
    "mobile/**/*.tsx",
    "context-engine/**/*.ts",
    "romania/**/*.ts",
    "marketplace/**/*.ts",
    "marketplace/**/*.tsx",
    "ui-kit/**/*.ts",
    "ui-kit/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "installer/**/*.ts",
    ".cicd/**/*.ts",
    "scripts/**/*.ts",
    "billing/**/*.ts",
    "admin/**/*.ts",
    "admin/**/*.tsx",
    "mobile-app/**/*.ts",
    "mobile-app/**/*.tsx",
    "themes/**/*.ts",
    "themes/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.spec.ts", "src/renderer/components/image/**"]
}
